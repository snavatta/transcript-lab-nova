# TranscriptLab Nova example configuration

ASPNETCORE_ENVIRONMENT=Development

# Frontend / backend origins
FRONTEND_PUBLIC_URL=http://localhost:4173
BACKEND_PUBLIC_URL=http://localhost:5180

# Storage
DATA_ROOT=/data
SQLITE_PATH=/data/transcriptlabnova.db

# Processing
TRANSCRIPTION_CONCURRENCY=1
ENABLE_GPU=false
DEFAULT_MODEL=small

# Media tooling
FFMPEG_PATH=/usr/bin/ffmpeg
