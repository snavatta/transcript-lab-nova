{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/transcriptlab.db"
  },
  "Storage": {
    "BasePath": "/data",
    "UploadsPath": "uploads",
    "AudioPath": "audio",
    "TranscriptsPath": "transcripts",
    "ExportsPath": "exports",
    "TempPath": "temp",
    "ModelsPath": "models"
  },
  "Transcription": {
    "WorkerConcurrency": 1,
    "PollingIntervalSeconds": 5,
    "FFmpegPath": "ffmpeg",
    "AutoDownloadModels": true,
    "ModelDownloadBaseUrl": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main",
    "SherpaOnnx": {
      "PythonPath": "python3",
      "AdapterScriptPath": "Tools/sherpa_onnx_adapter.py",
      "ModelsPath": "/data/models/sherpa-onnx",
      "Provider": "cpu",
      "NumThreads": 4
    }
  }
}
