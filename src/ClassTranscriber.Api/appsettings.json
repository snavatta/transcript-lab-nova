{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/transcriptlab.db"
  },
  "Storage": {
    "BasePath": "/data",
    "UploadsPath": "uploads",
    "AudioPath": "audio",
    "TranscriptsPath": "transcripts",
    "ExportsPath": "exports",
    "TempPath": "temp",
    "ModelsPath": "models"
  },
  "Uploads": {
    "MaxRequestBodySizeBytes": 1073741824
  },
  "Transcription": {
    "WorkerConcurrency": 1,
    "PollingIntervalSeconds": 5,
    "FFmpegPath": "ffmpeg",
    "AutoDownloadModels": true,
    "LogSegments": false,
    "ModelDownloadBaseUrl": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main",
    "SherpaOnnx": {
      "PythonPath": "python3",
      "AdapterScriptPath": "Tools/sherpa_onnx_adapter.py",
      "ModelsPath": "/data/models/sherpa-onnx",
      "Provider": "cpu",
      "NumThreads": 4,
      "AutoDownloadModels": true,
      "LogSegments": false,
      "ModelDownloadBaseUrl": "https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models",
      "WorkerPath": "ClassTranscriber.SherpaOnnx.Worker.dll",
      "DotNetHostPath": "dotnet"
    },
    "SherpaOnnxSenseVoice": {
      "ModelsPath": "/data/models/sherpa-onnx-sense-voice",
      "Provider": "cpu",
      "NumThreads": 4,
      "AutoDownloadModels": true,
      "LogSegments": false,
      "ModelDownloadBaseUrl": "https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models",
      "WorkerPath": "ClassTranscriber.SherpaOnnx.Worker.dll",
      "DotNetHostPath": "dotnet"
    },
    "WhisperNet": {
      "AutoDownloadModels": true,
      "LogSegments": false,
      "WorkerPath": "ClassTranscriber.WhisperNet.Worker.dll",
      "DotNetHostPath": "dotnet",
      "OpenVinoDevice": "GPU"
    },
    "OpenVinoGenAi": {
      "ModelsPath": "/data/models/openvino-genai",
      "AutoDownloadModels": true,
      "LogSegments": false,
      "ModelDownloadBaseUrl": "https://huggingface.co",
      "PythonPath": "python3",
      "WorkerScriptPath": "Tools/openvino_genai_worker.py",
      "Device": "GPU"
    }
  }
}
