# Stage 1: Build frontend
FROM node:lts-alpine AS frontend-build
WORKDIR /app/frontend
COPY src/frontend/package.json src/frontend/package-lock.json* ./
RUN npm ci
COPY src/frontend/ ./
RUN npm run build

# Stage 2: Build backend
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS backend-build
WORKDIR /app
COPY src/ClassTranscriber.slnx ./
COPY src/ClassTranscriber.Api/ClassTranscriber.Api.csproj ClassTranscriber.Api/
COPY src/ClassTranscriber.Api.Tests/ClassTranscriber.Api.Tests.csproj ClassTranscriber.Api.Tests/
COPY src/ClassTranscriber.SherpaOnnx.Worker/ClassTranscriber.SherpaOnnx.Worker.csproj ClassTranscriber.SherpaOnnx.Worker/
COPY src/ClassTranscriber.WhisperNet.Worker/ClassTranscriber.WhisperNet.Worker.csproj ClassTranscriber.WhisperNet.Worker/
RUN dotnet restore ClassTranscriber.slnx
COPY src/ClassTranscriber.Api/ ClassTranscriber.Api/
COPY src/ClassTranscriber.Api.Tests/ ClassTranscriber.Api.Tests/
COPY src/ClassTranscriber.SherpaOnnx.Worker/ ClassTranscriber.SherpaOnnx.Worker/
COPY src/ClassTranscriber.WhisperNet.Worker/ ClassTranscriber.WhisperNet.Worker/
RUN dotnet publish ClassTranscriber.Api/ClassTranscriber.Api.csproj -c Release -o /app/publish

# Stage 3: Harvest the .NET ASP.NET runtime from the official image
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS aspnet-runtime

# Stage 4: OpenVINO GenAI runtime
FROM docker.io/openvino/ubuntu24_runtime:2025.4.1 AS runtime

USER root
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        software-properties-common \
        ffmpeg \
        python3 \
        python3-venv \
    && add-apt-repository -y ppa:kobuk-team/intel-graphics \
    && apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        clinfo \
        intel-gsc \
        intel-metrics-discovery \
        intel-opencl-icd \
        libze-intel-gpu1 \
        libze1 \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/openvino-genai-venv \
    && /opt/openvino-genai-venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/openvino-genai-venv/bin/pip install --no-cache-dir \
        numpy \
        openvino==2025.4.1 \
        openvino-tokenizers==2025.4.1.0 \
        openvino-genai==2025.4.1.0

WORKDIR /app
COPY --from=aspnet-runtime /usr/share/dotnet /usr/share/dotnet
RUN ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet
COPY --from=backend-build /app/publish ./
COPY --from=frontend-build /app/frontend/dist ./wwwroot/

ENV ASPNETCORE_URLS=http://+:5000
ENV ASPNETCORE_ENVIRONMENT=Production
ENV Storage__BasePath=/data
ENV DOTNET_ROOT=/usr/share/dotnet
ENV PYTHONUNBUFFERED=1
ENV PATH=/opt/openvino-genai-venv/bin:${PATH}
ENV Transcription__OpenVinoGenAi__PythonPath=/opt/openvino-genai-venv/bin/python
ENV Transcription__OpenVinoGenAi__Device=GPU

EXPOSE 5000
VOLUME /data

ENTRYPOINT ["dotnet", "ClassTranscriber.Api.dll"]
